# ─── Meta / Instagram (из SETUP-META.md) ───────────────────────────
IG_APP_ID=
IG_APP_SECRET=
IG_USER_ID=
# Первичный долгоживущий токен. Дальше Vercel рефрешит его в Upstash и
# берёт оттуда. Эта env — только seed на случай пустого стора.
IG_LONG_LIVED_TOKEN=
# Строку придумываешь сам, та же вводится в Meta при подписке вебхука.
IG_WEBHOOK_VERIFY_TOKEN=

# ─── Claude (ответы в DM) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
# Модель ответов. Sonnet для скорости/цены, Opus для сложных сценариев.
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Upstash Redis (хранилище токена + дедуп вебхуков) ──────────────
# Создаётся в 1 клик в Vercel Marketplace → Upstash. Интеграция Vercel
# прокидывает имена KV_REST_API_* автоматически — их трогать не надо.
# Код читает KV_REST_API_*, а при их отсутствии — UPSTASH_REDIS_REST_*.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Альтернатива (если используешь Upstash напрямую, не через Vercel):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Секрет для /api/token (локалка тянет токен этим ключом) ────────
LOCAL_TOKEN_SECRET=

# ─── Cron (Vercel выставляет автоматически; для локального теста) ───
CRON_SECRET=

# ─── Telegram (алерт о скрытом запрещённом комментарии) ────────────
# Бот создаётся у @BotFather → токен. chat_id своего аккаунта узнаётся
# у @userinfobot (или из getUpdates после сообщения боту).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Только для локального скрипта публикации ──────────────────────
# Откуда локалка берёт токен (после деплоя — твой Vercel-домен).
VERCEL_BASE_URL=https://your-app.vercel.app

# Куда локалка заливает локальные файлы, чтобы получить публичный URL для
# Graph API. Нужны, только если публикуешь файл с диска (а не готовую ссылку).
# Берётся из Sanity → API. Токен — с правами на запись ассетов.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_WRITE_TOKEN=
